body,html{width:100%;height:100%;margin:0;background-color:#f5f5ff}
#centerCircle {
    width: 250px;
    height: 250px;
    background-color: #ffffff;
    background-image: url(<?php echo $grav_url; ?>);
    background-repeat: no-repeat;
    background-position: center bottom;
    background-size: 100%;
    border-radius: 200px;
    border: 8px solid #0A75AD;
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    margin: auto;
    max-width: 100%;
    max-height: 100%;
    overflow: auto;
}
